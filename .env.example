# ─────────────────────────────────────────────────────────────
#  Variables de entorno para el DEPLOY (VPS / Docker).
#  Copiá este archivo como  .env  y completá los valores reales.
#  El archivo .env NUNCA se sube a git (está en .gitignore).
#  Nota: .NET mapea la anidación de config con doble guion bajo "__".
# ─────────────────────────────────────────────────────────────

# Entorno
ASPNETCORE_ENVIRONMENT=Production

# Clave de firma del JWT — OBLIGATORIA y secreta (mín. 32 caracteres).
# Generá una aleatoria, por ejemplo:  openssl rand -base64 48
Jwt__Key=

# Cadena de conexión a SQL Server.
# En Docker apunta al servicio de la base (host = nombre del contenedor, ej. "db").
ConnectionStrings__AmrProdSeg=Server=db;Database=AmrProdSeg;User Id=sa;Password=CAMBIAR_PASSWORD_FUERTE;TrustServerCertificate=true;

# Contraseña del usuario 'sa' del contenedor de SQL Server (debe coincidir con la de arriba).
MSSQL_SA_PASSWORD=CAMBIAR_PASSWORD_FUERTE

# Dominio público (CORS + hosts permitidos + URL del QR del comprobante).
AllowedOrigin=https://amrprodseg.com
AllowedHosts=amrprodseg.com
PublicBaseUrl=https://amrprodseg.com

# ── Opcionales (también se pueden cargar desde la pantalla Configuración) ──
# SMTP (correo emisor)
# Smtp__Habilitado=true
# Smtp__Host=smtp.gmail.com
# Smtp__Port=587
# Smtp__Usuario=
# Smtp__Password=
# Smtp__From=

# Evolution API (WhatsApp)
# Evolution__Habilitado=true
# Evolution__BaseUrl=
# Evolution__Instance=
# Evolution__ApiKey=
